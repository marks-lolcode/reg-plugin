{
  "manifest_version": 3,
  "name": "CONvergence Check-In",
  "description": "Validates and processes CONvergence attendee check-ins via Neon CRM.",
  "author": "CONvergence IT — Matt Resong, Colleen Baltutis, Sean Berry, Mark Sauntry",
  "version": "2026.3",
  "icons": {
    "48": "assets/wink-with-note-black-48.png",
    "16": "assets/wink-black-16.png"
  },
  "content_scripts": [
    {
      "matches": [
        "https://ce.app.neoncrm.com/admin/accounts/*"
      ],
      "js": ["shared/js/constants-base.js", "config.js", "js/constants.js", "js/accountPage.js"],
      "run_at": "document_end"
    },
    {
      "matches": [
        "https://ce.app.neoncrm.com/np/admin/event/attendeeEdit.do*"
      ],
      "js": ["shared/js/constants-base.js", "config.js", "js/constants.js", "js/attendeeContact.js", "js/merch-attendee.js"],
      "run_at": "document_end"
    },
    {
      "matches": [
        "https://ce.app.neoncrm.com/np/admin/event/contactSelect.do*"
      ],
      "js": ["shared/js/constants-base.js", "config.js", "js/constants.js", "js/attendeeContact.js", "js/merch-attendee.js"],
      "run_at": "document_end"
    },
    {
      "matches": [
        "https://ce.app.neoncrm.com/np/admin/event/eventRegDetails.do*"
      ],
      "js": ["shared/js/constants-base.js", "config.js", "js/constants.js", "js/registrations.js"],
      "run_at": "document_end"
    }
  ],
  "permissions": ["storage", "tabs", "webNavigation", "scripting"],
  "host_permissions": [
    "https://ce.app.neoncrm.com/np/admin/event/*",
    "https://ce.app.neoncrm.com/admin/accounts/*"
  ],
  "action": {
    "default_icon": {
      "19": "assets/wink-black-19.png",
      "38": "assets/wink-black-38.png"
    },
    "default_title": "CONvergence Check-In",
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "js/background.js"
  },
  "options_ui": {
    "page": "extension_options_page.html",
    "open_in_tab": false
  }
}