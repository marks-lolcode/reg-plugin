.DS_Store
desktop.ini
Thumbs.db
*.swp
*.swo
.vscode/
.idea/

# ── Node (if anyone uses npm tools locally) ────────────────────────────
node_modules/
npm-debug.log

# ── Playwright test harness ────────────────────────────────────────────
.env
tests/.auth/
tests/.userdata/
test-results/
playwright-report/
