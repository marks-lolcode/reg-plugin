# Copy to .env (gitignored) and fill in.
# Only NEON_BASE_URL is required. Credentials are optional — the first test
# run pops a browser for manual login and saves session state to
# tests/.auth/state.json for reuse.

NEON_BASE_URL=https://ce.app.neoncrm.com

# Optional: if set, the login helper will attempt unattended login.
# Otherwise it waits up to 60s for you to log in manually.
NEON_USERNAME=
NEON_PASSWORD=

# Management override password (matches CONFIG.managementPasswordHash).
# Used by tests that exercise the override flow.
MANAGER_OVERRIDE_PASSWORD=reggie
